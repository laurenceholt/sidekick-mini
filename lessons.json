{
  "version": 4,
  "modules": [
    {
      "id": "m1",
      "title": "Rational Numbers",
      "sections": [
        {
          "id": "s1",
          "title": "Negatives",
          "lessons": [
            {
              "id": "l1",
              "title": "Negatives on the number line",
              "steps": [
                {
                  "type": "place-point",
                  "instruction": "Click 3 on this number line.",
                  "target": 3,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "place-point",
                  "instruction": "Put −3 on the number line.",
                  "target": -3,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "place-point",
                  "instruction": "By the way, we read \"-3\" as \"negative 3\". So now plot negative 1.",
                  "target": -1,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "number-line-choice",
                  "instruction": "Everything to the left of 0 is a negative number. The further left you go, the more negative. Which is more negative, −3 or −5?",
                  "points": [-3, -5],
                  "choices": [
                    { "text": "−3", "correct": false },
                    { "text": "−5", "correct": true }
                  ],
                  "hint": "More negative means further to the left.",
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "place-point",
                  "instruction": "Numbers to the right of 0 are positive. You can write \"+4\" or just \"4\". Plot +4.",
                  "target": 4,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "number-line-choice",
                  "instruction": "The further right you go, the more positive the number. Which is more positive, 2 or 5?",
                  "points": [2, 5],
                  "choices": [
                    { "text": "2", "correct": false },
                    { "text": "5", "correct": true }
                  ],
                  "hint": "More positive means further to the right.",
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "place-point",
                  "instruction": "Plot −3.",
                  "target": -3,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "move-point",
                  "instruction": "Add 2 to this point. Move it to where it should be.",
                  "startValue": -3,
                  "moveBy": 2,
                  "target": -1,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "number-line-choice",
                  "instruction": "When you add, you make the number greater. Greater is always to the right. Which of these is greater?",
                  "points": [-2, 2],
                  "choices": [
                    { "text": "−2", "correct": false },
                    { "text": "2", "correct": true }
                  ],
                  "hint": "Greater means further to the right on the number line.",
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "number-line-choice",
                  "instruction": "Which of these is greater?",
                  "points": [-5, -2],
                  "choices": [
                    { "text": "−5", "correct": false },
                    { "text": "−2", "correct": true }
                  ],
                  "hint": "Greater means further to the right on the number line.",
                  "min": -5,
                  "max": 5
                }
              ]
            },
            {
              "id": "l2",
              "title": "Negative operations",
              "steps": [
                {
                  "type": "place-point",
                  "instruction": "Plot −3.",
                  "target": -3,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "move-point",
                  "instruction": "Now add 2 to the point. Move it to where it should be.",
                  "startValue": -3,
                  "moveBy": 2,
                  "target": -1,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "equation-input",
                  "instruction": "What does −3 + 2 equal?",
                  "equation": "−3 + 2 = ",
                  "answer": -1,
                  "showNumberLine": true,
                  "ghostAt": -3,
                  "startValue": -3,
                  "endValue": -1,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "multiple-choice",
                  "instruction": "So to add a positive number like +2, you move RIGHT on the number line. Which way do you move to SUBTRACT +2?",
                  "choices": [
                    { "text": "left", "correct": true, "arrow": "left" },
                    { "text": "right", "correct": false, "arrow": "right" }
                  ]
                },
                {
                  "type": "place-point",
                  "instruction": "First, put 2 on the number line.",
                  "equationLabel": "2 − 6 = ",
                  "target": 2,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "move-point",
                  "instruction": "Now subtract 6. Move the point to the answer.",
                  "equationLabel": "2 − 6 = ",
                  "startValue": 2,
                  "moveBy": -6,
                  "target": -4,
                  "min": -5,
                  "max": 5
                },
                {
                  "type": "equation-input",
                  "instruction": "What does 2 − 6 equal?",
                  "equation": "2 − 6 = ",
                  "answer": -4,
                  "showNumberLine": true,
                  "ghostAt": 2,
                  "startValue": 2,
                  "endValue": -4,
                  "min": -5,
                  "max": 5
                }
              ]
            },
            {
              "id": "l3",
              "title": "Negatives in real life",
              "steps": []
            }
          ]
        }
      ]
    }
  ]
}
